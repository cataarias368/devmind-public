# ============================================================
# DevMind Agent v3.0 - Configuración de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores

# --- OBLIGATORIO ---
GLM_API_KEY=tu_api_key_aqui

# --- AUTENTICACIÓN API ---
# Clave separada para autenticar Dashboard y REST API.
# Si no se configura, se usa GLM_API_KEY como fallback (NO recomendado para producción).
API_AUTH_KEY=

# --- CORS ---
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- GENERAL ---
WORKSPACE_ROOT=./workspace
AGENT_DRY_RUN=false
AGENT_MAX_STEPS=25
DASHBOARD_PORT=3001
API_PORT=3000

# --- GITHUB (Opcional) ---
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# --- SLACK (Opcional) ---
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# --- DISCORD (Opcional) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# --- TELEGRAM (Opcional) ---
TELEGRAM_TOKEN=

# --- SLACK WEBHOOK (Opcional - para alertas) ---
SLACK_WEBHOOK_URL=

# ============================================================
# DevMind 3.0 - Multi-Modelo
# ============================================================

# --- Proveedores LLM adicionales (Opcional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_HOST=

# --- Modelo preferido (Opcional) ---
# ID del modelo a usar por defecto: glm-4, glm-4-flash, gpt-4o, gpt-4o-mini, claude-sonnet-4, gemini-2.5-pro, local-codeqwen
PREFERRED_MODEL=

# --- Auto-Mutación (Opcional) ---
# Cambia automáticamente al mejor modelo según la tarea
AUTO_MUTATION=false

# ============================================================
# DevMind 3.0 - A2A Protocol (Agent-to-Agent)
# ============================================================

# --- Habilitar protocolo A2A ---
A2A_ENABLED=false

# --- Nombre del nodo A2A ---
A2A_NODE_NAME=DevMind-Agent

# --- Puerto A2A ---
A2A_PORT=4000

# ============================================================
# DevMind 3.0 - Proveedores API (Enrutamiento)
# ============================================================

# --- Google AI Studio (Gemini) ---
GOOGLE_API_KEY=

# --- Mistral AI ---
MISTRAL_API_KEY=

# --- Groq (Ultra rapido) ---
GROQ_API_KEY=

# --- OpenRouter ---
OPENROUTER_API_KEY=

# --- Cloudflare Workers AI ---
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================
# DevMind 3.0 - Identidad y Proteccion
# ============================================================

# La identidad esta encriptada en el codigo (src/core/identity.ts)
# No es necesario configurar estas variables manualmente.
# El sistema verifica automaticamente la integridad al arrancar.
DEVMIND_IDENTITY=DevMind-Agent
DEVMIND_OWNER=Jose-Luis-Arias-Casco
DEVMIND_EMAIL=cataarias368@gmail.com
DEVMIND_REPO=https://github.com/cataarias368/devmind-agent
