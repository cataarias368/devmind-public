# ============================================================
# DevMind Agent - Configuración de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores

# --- OBLIGATORIO ---
GLM_API_KEY=tu_api_key_aqui

# --- AUTENTICACIÓN API ---
# Clave separada para autenticar Dashboard y REST API.
# Si no se configura, se usa GLM_API_KEY como fallback (NO recomendado para producción).
API_AUTH_KEY=

# --- CORS ---
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- GENERAL ---
WORKSPACE_ROOT=./workspace
AGENT_DRY_RUN=false
AGENT_MAX_STEPS=25
DASHBOARD_PORT=3001
API_PORT=3000

# --- GITHUB (Opcional) ---
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# --- SLACK (Opcional) ---
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# --- DISCORD (Opcional) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# --- TELEGRAM (Opcional) ---
TELEGRAM_TOKEN=

# --- SLACK WEBHOOK (Opcional - para alertas) ---
SLACK_WEBHOOK_URL=
