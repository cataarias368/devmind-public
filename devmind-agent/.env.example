# ============================================================
# DevMind Agent v3.0 - Configuracion de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores
# Al menos UN proveedor LLM debe estar configurado

# --- Proveedores LLM (al menos uno requerido) ---

# Cloudflare Workers AI (Llama 3.3 70B - Gratuito)
# Obtener en: https://dash.cloudflare.com/ > AI > Workers AI
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Groq (Llama 3.3 70B - Gratuito)
# Obtener en: https://console.groq.com/
GROQ_API_KEY=

# Google AI Studio (Gemini 2.5 - Gratuito)
# Obtener en: https://aistudio.google.com/
GOOGLE_AI_API_KEY=

# Mistral AI (Mistral Small - Gratuito)
# Obtener en: https://console.mistral.ai/
MISTRAL_API_KEY=

# OpenRouter (Multi-modelo - Plan gratuito disponible)
# Obtener en: https://openrouter.ai/
OPENROUTER_API_KEY=

# GLM-4 (Proveedor principal original)
# Obtener en: https://open.bigmodel.cn/
GLM_API_KEY=

# OpenAI (Pago)
OPENAI_API_KEY=

# Anthropic (Pago)
ANTHROPIC_API_KEY=

# --- AUTENTICACION API ---
# Clave para autenticar Dashboard y REST API.
# Si no se configura, se usa la primera API key disponible.
API_AUTH_KEY=devmind-local-dev

# --- CORS ---
# Origenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- GENERAL ---
WORKSPACE_ROOT=./workspace
AGENT_DRY_RUN=false
AGENT_MAX_STEPS=25
DASHBOARD_PORT=3001
API_PORT=3000

# --- GITHUB (Opcional) ---
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# --- SLACK (Opcional) ---
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# --- DISCORD (Opcional) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# --- TELEGRAM (Opcional) ---
TELEGRAM_TOKEN=

# --- SLACK WEBHOOK (Opcional - para alertas) ---
SLACK_WEBHOOK_URL=

# --- Modelo preferido (Opcional) ---
PREFERRED_MODEL=

# --- Auto-Mutacion ---
# Habilitar mutacion automatica del codigo
AUTO_MUTATION=false

# ============================================================
# DevMind 3.0 - A2A Protocol (Agent-to-Agent)
# ============================================================

A2A_ENABLED=false
A2A_NODE_NAME=DevMind-Agent
A2A_PORT=4000
