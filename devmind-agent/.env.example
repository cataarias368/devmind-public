# ============================================================
# DevMind Agent - Configuración de Entorno
# ============================================================
# Copiar este archivo como .env y completar los valores

# --- OBLIGATORIO ---
GLM_API_KEY=tu_api_key_aqui

# --- GENERAL ---
WORKSPACE_ROOT=./workspace
AGENT_DRY_RUN=false
AGENT_MAX_STEPS=25
DASHBOARD_PORT=3001
API_PORT=3000

# --- GITHUB (Opcional) ---
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# --- SLACK (Opcional) ---
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# --- DISCORD (Opcional) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# --- TELEGRAM (Opcional) ---
TELEGRAM_TOKEN=
