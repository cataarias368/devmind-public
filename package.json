{
  "name": "devmind-public",
  "version": "3.0.0",
  "description": "🧠 DevMind Agent — Open Source Autonomous Software Engineering",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "devmind": "./bin/devmind.js"
  },
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx --watch src/index.ts",
    "postinstall": "git submodule update --init --recursive",
    "update": "git submodule update --remote",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cataarias368/devmind-public.git"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "coding-assistant",
    "glm",
    "devops"
  ],
  "author": "Jose Luis Arias Casco <cataarias368@gmail.com>",
  "license": "AGPL-3.0",
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
