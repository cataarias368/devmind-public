{
  "name": "devmind-agent",
  "version": "3.0.0",
  "description": "Sistema de Ingeniería de Software Autónoma - DevMind Agent",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx --watch src/index.ts",
    "cli": "npx tsx src/index.ts --cli",
    "dashboard": "npx tsx src/index.ts --dashboard",
    "api": "npx tsx src/index.ts --server",
    "all": "npx tsx src/index.ts --all",
    "docs": "npx tsx src/index.ts --docs",
    "test": "npx tsx src/index.ts --test src/",
    "analyze": "npx tsx src/index.ts --analyze",
    "multi-agent": "npx tsx src/index.ts --multi-agent",
    "bots": "npx tsx src/index.ts --bots",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.6",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.3.0",
    "groq-sdk": "^1.2.1",
    "sharp": "^0.35.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "agent",
    "autonomous",
    "devops",
    "ai",
    "glm"
  ],
  "license": "AGPL-3.0"
}
